{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "mcp__excalidraw__create_view",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/ensure-server.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "mcp__excalidraw__create_view",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/write-preview.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
