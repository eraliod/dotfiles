{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "BASH_DEFAULT_TIMEOUT_MS": "30000",
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "1",
    "DISABLE_TELEMETRY": "1",
    "MAX_MCP_OUTPUT_TOKENS": "40000",
    "MAX_THINKING_TOKENS": "10000",
    "SLASH_COMMAND_TOOL_CHAR_BUDGET": "30000"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "__ READ-ONLY CLI __",
      "Bash(brew info:*)",
      "Bash(cat:*)",
      "Bash(code --list-extensions:*)",
      "Bash(difft:*)",
      "Bash(head:*)",
      "Bash(ls:*)",
      "Bash(printf:*)",
      "Bash(readlink:*)",
      "Bash(tail:*)",
      "Bash(test:*)",
      "Bash(tree:*)",
      "Bash(wc:*)",
      "Read(~/Documents/code/**)",
      "Read(~/dotfiles/**)",
      "Read(~/.claude/**)",
      "__ SEARCH __",
      "Bash(ast-grep:*)",
      "Bash(fd:*)",
      "Bash(fzf:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "__ DATA PROCESSING __",
      "Bash(jq:*)",
      "Bash(yq:*)",
      "__ GIT READ-ONLY __",
      "Bash(git blame:*)",
      "Bash(git check-ignore:*)",
      "Bash(git worktree add:*)",
      "Bash(git worktree list:*)",
      "Bash(git worktree lock:*)",
      "Bash(git worktree unlock:*)",
      "Bash(git worktree repair:*)",
      "Bash(git worktree prune:*)",
      "Bash(git describe:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git ls-files:*)",
      "Bash(git ls-tree:*)",
      "Bash(git remote:*)",
      "Bash(git rev-parse:*)",
      "Bash(git shortlog:*)",
      "Bash(git show:*)",
      "Bash(git stash list:*)",
      "Bash(git status:*)",
      "__ GIT WRITE OPS (NON-DESTRUCTIVE) __",
      "Bash(git add:*)",
      "__ LEGION VAULT SYNC (scoped to ~/Documents/legion; see /legion) __",
      "Read(~/Documents/legion/**)",
      "Edit(~/Documents/legion/**)",
      "Bash(git -C ~/Documents/legion add:*)",
      "Bash(git -C ~/Documents/legion rm:*)",
      "Bash(git -C ~/Documents/legion status:*)",
      "Bash(git -C ~/Documents/legion ls-files:*)",
      "Bash(git -C ~/Documents/legion rev-parse:*)",
      "Bash(git -C ~/Documents/legion remote:*)",
      "Bash(git -C ~/Documents/legion pull:*)",
      "Bash(git -C ~/Documents/legion rebase:*)",
      "Bash(git -C ~/Documents/legion commit:*)",
      "Bash(git -C ~/Documents/legion push:*)",
      "__ GITHUB CLI READ-ONLY __",
      "Bash(gh * list *)",
      "Bash(gh * view *)",
      "Bash(gh * status *)",
      "Bash(gh * diff *)",
      "Bash(gh * checks *)",
      "__ LINTING/CHECKING __",
      "Bash(* pytest *)",
      "Bash(* ruff *)",
      "Bash(* ty *)",
      "Bash(pre-commit run:*)",
      "Bash(prek run:*)",
      "Bash(*sqruff*)",
      "__ UNIVERSAL FLAGS __",
      "Bash(* --help)",
      "Bash(* -h)",
      "Bash(* --version)",
      "Bash(* -V)",
      "__ WEB __",
      "WebFetch(domain:*)",
      "WebSearch",
      "__ DATABRICKS CLI (READ-ONLY, ALL WORKSPACES) __",
      "Bash(databricks * list*)",
      "Bash(databricks * get*)",
      "Bash(databricks * describe*)",
      "Bash(databricks * export*)",
      "Bash(databricks auth profiles*)",
      "Bash(databricks auth env*)",
      "__ PYTHON PACKAGE MANAGERS (READ-ONLY) __",
      "Bash(pixi search:*)",
      "__ CLAUDE CLI __",
      "Bash(claude mcp list:*)",
      "__ MCP TOOLS __",
      "mcp__plugin_databricks-mcp-custom_databricks-dbsql-dev__execute_sql_read_only",
      "mcp__plugin_databricks-mcp-custom_databricks-dbsql-dev__poll_sql_result",
      "mcp__plugin_databricks-mcp-custom_databricks-dbsql-prod__execute_sql_read_only",
      "mcp__plugin_databricks-mcp-custom_databricks-dbsql-prod__poll_sql_result",
      "mcp__plugin_databricks-mcp-custom_databricks-dbsql-sandbox__execute_sql_read_only",
      "mcp__plugin_databricks-mcp-custom_databricks-dbsql-sandbox__poll_sql_result",
      "mcp__plugin_databricks-mcp-custom_databricks-dbsql-adhoc-analysis__execute_sql_read_only",
      "mcp__plugin_databricks-mcp-custom_databricks-dbsql-adhoc-analysis__poll_sql_result",
      "__ REDSHIFT MCP (read fast-path; writes gated by plugin hook) __",
      "mcp__plugin_redshift-mcp_redshift-legacy",
      "mcp__plugin_redshift-mcp_redshift-analytics-dev",
      "mcp__plugin_redshift-mcp_redshift-analytics-prod",
      "mcp__plugin_atlassian-toolkit_atlassian-mcp",
      "mcp__plugin_episodic-memory_episodic-memory",
      "mcp__plugin_excalidraw-preview_excalidraw",
      "mcp__private-journal",
      "mcp__ide",
      "__ SKILLS __",
      "Skill(*)"
    ],
    "deny": [
      "__ GIT DESTRUCTIVE __",
      "Bash(git clean -f:*)",
      "Bash(git commit --no-verify:*)",
      "Bash(git commit -n:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "__ PRE-COMMIT BYPASS __",
      "Bash(SKIP=:*)",
      "Bash(pre-commit uninstall:*)",
      "Bash(prek uninstall:*)",
      "__ SECRETS __",
      "Read(**/.env*)",
      "Read(~/.aws/**)",
      "Read(~/.config/gcloud/**)",
      "Read(~/.databricks/**)",
      "Read(**/.private)",
      "Read(~/.ssh/**)"
    ],
    "ask": [
      "Bash(databricks auth token*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "mcp__plugin_databricks-mcp-custom_databricks-dbsql-dev__execute_sql",
      "mcp__plugin_databricks-mcp-custom_databricks-dbsql-prod__execute_sql",
      "mcp__plugin_databricks-mcp-custom_databricks-dbsql-sandbox__execute_sql",
      "mcp__plugin_databricks-mcp-custom_databricks-dbsql-adhoc-analysis__execute_sql"
    ],
    "defaultMode": "acceptEdits",
    "disableBypassPermissionsMode": "disable"
  },
  "model": "opus[1m]",
  "enableAllProjectMcpServers": true,
  "hooks": {},
  "statusLine": {
    "type": "command",
    "command": "input=$(cat); cwd=$(echo \"$input\" | jq -r '.workspace.current_dir'); dir=$(basename \"$cwd\"); branch=$(git -C \"$cwd\" rev-parse --abbrev-ref HEAD 2>/dev/null | grep -oE '^[A-Z]+-[0-9]+'); model=$(echo \"$input\" | jq -r '.model.display_name' 2>/dev/null || echo 'Claude'); ctx=$(echo \"$input\" | jq -r '.context_window.used_percentage' 2>/dev/null || echo '0'); [ -n \"$branch\" ] && printf '\\e[36m%s\\e[0m \\e[2m(%s)\\e[0m [%s] \\e[33m%s%%\\e[0m' \"$dir\" \"$branch\" \"$model\" \"$ctx\" || printf '\\e[36m%s\\e[0m [%s] \\e[33m%s%%\\e[0m' \"$dir\" \"$model\" \"$ctx\""
  },
  "enabledPlugins": {
    "excalidraw-preview@dotfile-plugins": true,
    "redshift-mcp@dotfile-plugins": true,
    "databricks-mcp-custom@dotfile-plugins": true,
    "superpowers@superpowers-marketplace": true,
    "episodic-memory@superpowers-marketplace": true,
    "superpowers-lab@superpowers-marketplace": true,
    "atlassian-toolkit@kin-claude-plugins": true,
    "readme-forge@kin-claude-plugins": true,
    "code-review@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "hookify@claude-plugins-official": true,
    "plugin-dev@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "superpowers-developing-for-claude-code@superpowers-marketplace": true,
    "planning-with-files@planning-with-files": true,
    "kin-design-system@kin-claude-plugins": true,
    "astral@astral-sh": true,
    "feature-dev@claude-plugins-official": true,
    "agent-sdk-dev@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "terraform-ls@kin-claude-plugins": true,
    "learning-output-style@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "dotfile-plugins": {
      "source": {
        "source": "directory",
        "path": "/Users/damian.eralio/dotfiles"
      }
    },
    "superpowers-marketplace": {
      "source": {
        "source": "github",
        "repo": "obra/superpowers-marketplace"
      }
    },
    "kin-claude-plugins": {
      "source": {
